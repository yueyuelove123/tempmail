# ============================================================
# TempMail 环境变量模板
# 复制为 .env 并填写实际值：cp .env.example .env
# ============================================================
#
# ╔══════════════════════════════════════════════════════════════════╗
# ║  端口修改总指南                                                   ║
# ╠══════════════╦═══════════════════════════════════════════════════╣
# ║ 修改 Web 端口 ║ 本文件 WEB_PORT=xxxx（仅宿主机端口）              ║
# ╠══════════════╬═══════════════════════════════════════════════════╣
# ║ 修改 API 端口 ║ 1. 本文件 API_PORT=xxxx                           ║
# ║ (容器内 8967) ║ 2. 本文件 API_DB_DSN 中 @pgbouncer:6432 不要动    ║
# ║              ║ 3. docker-compose.yml api.ports 右边改成 xxxx      ║
# ║              ║ 4. nginx/default.conf 所有 api:8967 改成 api:xxxx  ║
# ║              ║ 5. postfix/entrypoint.sh api:8967 改成 api:xxxx   ║
# ║              ║ 6. postfix/mail-receiver.py API_URL 默认值改掉     ║
# ╠══════════════╬═══════════════════════════════════════════════════╣
# ║ 修改 SMTP 端口║ 仅改 docker-compose.yml postfix.ports 左边数字    ║
# ║ (容器内 25)   ║ 注意：外部 MX 投信必须用 25，改端口只影响本地测试  ║
# ╚══════════════╩═══════════════════════════════════════════════════╝

# ---------- Web ----------
# WEB_PORT：前端 Web 的宿主机端口，容器内仍监听 80。
# 默认 8888，避免与宿主机已有 OpenResty/Nginx 的 80 冲突。
# 若宿主机 80 未被占用并希望直接用 http://<服务器IP> 访问，可改为 80。
WEB_PORT=8888

# ---------- PostgreSQL ----------
POSTGRES_DB=tempmail
POSTGRES_USER=tempmail
POSTGRES_PASSWORD=change_me_strong_password

# ---------- PgBouncer ----------
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=2000
PGBOUNCER_DEFAULT_POOL_SIZE=50
PGBOUNCER_MIN_POOL_SIZE=10

# ---------- Redis ----------
REDIS_PASSWORD=change_me_redis_password

# ---------- API Server ----------
# ★ API_PORT：Go API 容器内监听的端口，默认 8967。
# 修改此值后，必须同步修改以下文件，否则 Nginx 和 Postfix 无法找到 API：
#   - docker-compose.yml：api.ports 右边数字改成一样的值
#   - nginx/default.conf：所有 proxy_pass http://api:8967 中的 8967
#   - postfix/entrypoint.sh：curl http://api:8967 中的 8967
#   - postfix/mail-receiver.py：API_URL 环境变量默认值 http://api:8967
API_PORT=8967
# ★ API_DB_DSN：数据库连接串，@pgbouncer:6432 是容器内部地址，不要改。
# 只需要把 change_me_strong_password 改成和 POSTGRES_PASSWORD 一样的值。
API_DB_DSN=postgres://tempmail:change_me_strong_password@pgbouncer:6432/tempmail?sslmode=disable
# ★ API_REDIS_ADDR：Redis 容器内部地址，redis:6379 不要改（容器间内网通信）。
API_REDIS_ADDR=redis:6379
# ★ API_REDIS_PASSWORD：改成和 REDIS_PASSWORD 一样的值。
API_REDIS_PASSWORD=change_me_redis_password
# API_RATE_LIMIT 和 API_RATE_WINDOW：API 速率限制，默认 500 次/分钟。
API_RATE_LIMIT=500
API_RATE_WINDOW=60

# ---------- Admin ----------
ADMIN_USERNAME=admin

# ---------- SMTP / Mail ----------
# 服务器公网 IP，用于 MX 验证与 SPF 生成
SMTP_SERVER_IP=1.2.3.4
# 邮件服务器主机名（如 mail.yourdomain.com）。
# 设置后用户添加域名仅需一条 MX 记录，无需额外 A 记录。
SMTP_HOSTNAME=mail.yourdomain.com
